# Copia in `.env` (non versionato) e adatta. Tutte le chiavi hanno prefisso TT_.

# --- Persistenza ---
# Sviluppo (default): SQLite locale.
# TT_DATABASE_URL=sqlite:///./transito.db
# Produzione / stack docker-compose:
# TT_DATABASE_URL=postgresql+psycopg://transito:transito@localhost:5432/transito

# --- Cache ---
# Vuoto → cache in-memory. Con docker-compose:
# TT_REDIS_URL=redis://localhost:6379/0

# --- Sorgenti dati (override solo se gli URL ufficiali cambiano) ---
# TT_GTFS_STATIC_URL=...
# TT_RT_VEHICLE_POSITIONS_URL=...
# TT_RT_TRIP_UPDATES_URL=...
# TT_RT_ALERTS_URL=...
# TT_STRIKES_CSV_URL=...
